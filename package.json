{
  "name": "@cosmonic-labs/mcp-server-template",
  "version": "1.0.0",
  "description": "Template for MCP Servers",
  "keywords": [
    "wasm",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-server-template",
    "agent",
    "ai",
    "starter",
    "template",
    "generator"
  ],
  "homepage": "https://github.com/cosmonic-labs/mcp-server-template#readme",
  "bugs": {
    "url": "https://github.com/cosmonic-labs/mcp-server-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmonic-labs/mcp-server-template.git"
  },
  "scripts": {
    "fetch:wit": "wash wit fetch",
    "generate:types": "rimraf generated/types && jco guest-types wit/ -o generated/types",
    "setup:wit": "npm run fetch:wit && npm run generate:types",
    "build:ts": "rollup -c",
    "build:component": "jco componentize -w wit -o dist/component.wasm dist/component.js",
    "build": "npm run generate:types && npm run build:ts && npm run build:component",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css}\"",
    "format-ci": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css}\"",
    "lint": "eslint src/**/*.js",
    "start": "npm run dev",
    "serve:wasmtime": "wasmtime serve -Scli dist/component.wasm",
    "dev": "concurrently \"nodemon\" \"wait-on http-get://localhost:8000 && mcp-inspector --transport http --server-url http://localhost:8000/v1/mcp\"",
    "test": "npm run test:e2e",
    "test:smoke": "PORT=8000 scripts/test.bash",
    "test:e2e": "vitest -c test/vitest.e2e.ts --run",
    "openapi2mcp": "openapi2mcp $1 --project-path .",
    "inspector": "mcp-inspector --transport http --server-url http://localhost:8000/v1/mcp",
    "enable-feature": "node scripts/feature.js enable",
    "disable-feature": "node scripts/feature.js disable"
  },
  "license": "Apache-2.0",
  "author": "Cosmonic",
  "type": "module",
  "main": "dist/component.js",
  "devDependencies": {
    "@bytecodealliance/componentize-js": "^0.20.0",
    "@bytecodealliance/jco": "^1.13.0",
    "@cosmonic-labs/openapi2mcp": "0.9.0",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/folder-hash": "^4.0.4",
    "@types/node": "^25.7.0",
    "concurrently": "^9.0.0",
    "eslint": "^10.3.0",
    "folder-hash": "^4.1.1",
    "globals": "^17.6.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "rollup": "^4.41.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@hono/mcp": "^0.2.2",
    "@hono/node-server": "^2.0.2",
    "@hono/swagger-ui": "^0.6.1",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "hono": "^4.9.10",
    "zod": "^4.4.3"
  }
}
